{
  "conventionalCommits.promptBody": false,
  "conventionalCommits.promptFooter": false,
  "conventionalCommits.promptScopes": false,
  "cSpell.words": ["conventionalcommits", "ShalaDarpan"],
  "js/ts.tsdk.path": "node_modules/typescript/lib",
  "tailwindCSS.classFunctions": ["(.+).classList.(add|remove)"],
  "tailwindCSS.experimental.classRegex": [["className ?\\=([^;]*)", "'([^']*)'"]],
  "tailwindCSS.experimental.configFile": {
    "src/assets/tailwind.css": "src/entrypoints/*.content.ts"
  }
}
