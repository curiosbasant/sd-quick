{
  "conventionalCommits.promptBody": false,
  "conventionalCommits.promptFooter": false,
  "conventionalCommits.scopes": ["ext", "mobile"],
  "cSpell.words": ["conventionalcommits", "ShalaDarpan"],
  "editor.codeActionsOnSave": {
    "source.sortImports": "never"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "tailwindCSS.classFunctions": ["(.+).classList.(add|remove)", "cn", "cx", "tv"],
  "tailwindCSS.experimental.classRegex": [["className ?\\=([^;]*)", "'([^']*)'"]],
  "tailwindCSS.experimental.configFile": {
    "apps/extenstion/src/assets/tailwind.css": "apps/extenstion/src/entrypoints/*.content.ts",
    "apps/mobile/src/styles.css": "apps/mobile/src/**/*.tsx"
  },
  "typescript.tsdk": "node_modules/typescript/lib"
}
