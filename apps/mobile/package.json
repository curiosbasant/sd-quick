{
  "name": "@sd/mobile",
  "version": "0.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "pnpm run set-hostname expo start --go",
    "android": "pnpm run set-hostname expo start --android",
    "ios": "expo start --ios",
    "build:local": "eas build --profile development --platform android --local",
    "set-hostname": "REACT_NATIVE_PACKAGER_HOSTNAME=$(netsh.exe interface ip show address 'WiFi' | grep 'IP Address' | sed -E 's/^.*IP Address:[[:space:]]*//')",
    "env:pull": "eas env:pull development",
    "use-emulator": "node ./scripts/use-emulator.mjs",
    "": ""
  },
  "dependencies": {
    "@react-native-picker/picker": "2.11.1",
    "expo": "~54.0.30",
    "expo-constants": "~18.0.12",
    "expo-dev-client": "~6.0.20",
    "expo-linking": "~8.0.11",
    "expo-network": "~8.0.8",
    "expo-router": "~6.0.21",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.15",
    "googleapis": "^169.0.0",
    "nativewind": "5.0.0-preview.2",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css": "3.0.1",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-reanimated": "~4.1.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "tailwind-merge": "3.4.0",
    "tailwind-variants": "3.2.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.18",
    "@types/react": "~19.1.10",
    "postcss": "8.5.6",
    "tailwindcss": "^4.1.7",
    "typescript": "~5.9.2"
  },
  "private": true
}
