{
  "name": "sd-quick",
  "scripts": {
    "ifl": "pnpm install --frozen-lockfile",
    "format": "prettier -w \"**/*.{js,ts,tsx}\" -u --ignore-path .gitignore"
  },
  "devDependencies": {
    "@sd/prettier-config": "workspace:*"
  },
  "pnpm": {
    "overrides": {
      "lightningcss": "1.30.1"
    }
  },
  "packageManager": "pnpm@10.12.1",
  "prettier": "@sd/prettier-config",
  "private": true
}
